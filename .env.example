# ─── PUBLIC (Safe to expose in client) ───────────────────────────────────────
# VAPID public key — used by the browser client to subscribe to push notifications
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# ─── SERVER-ONLY SECRETS (Must be set in Netlify Dashboard → Environment Variables) ──
# VAPID keys — for web-push package on server (not used with FCM, kept for reference)
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_SUBJECT=mailto:your-email@example.com

# Firebase Admin SDK credentials (paste the entire JSON as a single-line string)
# Get this from Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"YOUR_PROJECT_ID",...}'

# ─── OPTIONAL ────────────────────────────────────────────────────────────────
PING_MESSAGE="ping pong"
VITE_PUBLIC_BUILDER_KEY=__BUILDER_PUBLIC_KEY__
